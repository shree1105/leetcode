class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        for n in range(len(nums)):
            for m in range(n+1,len(nums)):
                if nums[n]+nums[m] == target:
                    return [n,m]

if __name__ == "__main__":
    nums = [4,6,2,8]
    target = 10
    solution = Solution()
    result = solution.twoSum(nums, target)
    print(result)