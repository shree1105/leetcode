class Solution(object):
    def isPalindrome(self, x):
        """
        :type x: int
        :rtype: bool
        """
        s=str(x)
        if s==s[::-1]:
            return True
        return False

if __name__ == "__main__":
    x = 121
    solution = Solution()
    result = solution.isPalindrome(x)
    print(result)